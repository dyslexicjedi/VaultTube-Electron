{
  "name": "vaulttube-macos",
  "version": "1.0.0",
  "description": "VaultTube Desktop Application for MacOS",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyslexicjedi/VaultTube-Electron.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect"
  },
  "keywords": [
    "electron",
    "macos",
    "video",
    "vaulttube"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.7.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "type": "commonjs",
  "build": {
    "appId": "com.vaulttube.macos",
    "publish": {
      "provider": "github",
      "owner": "dyslexicjedi",
      "repo": "VaultTube-Electron"
    },
    "mac": {
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        },
        {
          "target": "mas",
          "arch": ["universal"]
        }
        ]
    }
    }
}
