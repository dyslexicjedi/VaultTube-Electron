{
  "name": "vaulttube-electron",
  "version": "0.2.0",
  "description": "VaultTube Desktop Application for Electron",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyslexicjedi/VaultTube-Electron.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect"
  },
  "keywords": [
    "electron",
    "macos",
    "linux",
    "video",
    "vaulttube"
  ],
  "author": {
    "name": "dyslexicjedi",
    "email": "rob@dyslexicjedi.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.7.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "type": "commonjs",
  "build": {
    "appId": "com.vaulttube.electron",
    "publish": {
      "provider": "github",
      "owner": "dyslexicjedi",
      "repo": "VaultTube-Electron"
    },
    "mac": {
      "category": "public.app-category.video",
      "target": ["dmg", "zip"]
    },
    "linux": {
      "category": "Video",
      "target": [
        {
          "target": "AppImage",
          "arch": ["arm64"]
        },
        {
          "target": "deb",
          "arch": ["arm64"]
        },
        {
          "target": "rpm",
          "arch": ["arm64"]
        }
      ]
    }
    }
}
